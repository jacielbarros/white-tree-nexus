{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "wtnadmin",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "wtnadmin", "start", "--", "--port", "4200", "--host", "127.0.0.1"],
      "port": 4200,
      "autoPort": false
    },
    {
      "name": "backend",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "wtnapp.main:app", "--port", "8000"],
      "port": 8000
    }
  ]
}
