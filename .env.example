# White Tree Nexus — backend (.env.example). Copie para .env e ajuste.

# --- Core ---
DATABASE_URL=postgresql+psycopg://postgres:password@localhost/wtndatabase
JWT_SECRET_KEY=change-me-64-byte-hex
JWT_ISSUER=white-tree-nexus
TOKEN_EXPIRY_MINUTES=20
RESET_TOKEN_EXPIRY_MINUTES=30
REDIS_URL=redis://localhost:6379/0
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# --- Autenticação / bloqueio ---
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
PASSWORD_MIN_LENGTH=12

# --- Convites / bootstrap ---
INVITE_EXPIRY_HOURS=72
BOOTSTRAP_TOKEN=

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_PASSWORD_REQUEST=3/minute

# --- E-mail (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@example.com

# --- Protecao de dados sensiveis em repouso ---
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# --- Storage local de evidencias documentais ---
EVIDENCE_STORAGE_DIR=./evidence_store/
EVIDENCE_MAX_FILE_BYTES=20971520
EVIDENCE_ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.webp,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.csv,.zip,.7z
